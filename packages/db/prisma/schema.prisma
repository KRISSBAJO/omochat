}

model MediaAsset {
  id         String        @id @default(uuid()) @db.Uuid
  messageId  String?       @db.Uuid
  provider   MediaProvider @default(CLOUDINARY)
  bucket     String?
  storageKey String
  url        String
  mimeType   String
  sizeBytes  Int
  width      Int?
  height     Int?
  durationMs Int?
  checksum   String?
  createdAt  DateTime      @default(now())
  message    Message?      @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([messageId])
  @@index([storageKey])
  @@map("media_assets")
}

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  userId    String             @db.Uuid
  messageId String?            @db.Uuid
  type      NotificationType   @default(SYSTEM)
  contextId String?
  title     String
  body      String
  status    NotificationStatus @default(PENDING)
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   Message?           @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@index([messageId])
  @@map("notifications")
}

model UserBlock {
  id            String   @id @default(uuid()) @db.Uuid
  blockerUserId String   @db.Uuid
  blockedUserId String   @db.Uuid
  createdAt     DateTime @default(now())
  blocker       User     @relation("UserBlocksInitiated", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked       User     @relation("UserBlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockerUserId])
  @@index([blockedUserId])
  @@map("user_blocks")
}

model UserReport {
  id                     String           @id @default(uuid()) @db.Uuid
  reporterUserId         String           @db.Uuid
  targetUserId           String           @db.Uuid
  conversationId         String?          @db.Uuid
  messageId              String?          @db.Uuid
  assignedModeratorUserId String?         @db.Uuid
  reviewedByUserId       String?          @db.Uuid
  reason                 String
  details                String?
  moderatorNote          String?
  resolutionNote         String?
  status                 UserReportStatus @default(OPEN)
  assignedAt             DateTime?
  reviewedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  reporter               User             @relation("UserReportsFiled", fields: [reporterUserId], references: [id], onDelete: Cascade)
  target                 User             @relation("UserReportsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  assignedModerator      User?            @relation("UserReportsAssigned", fields: [assignedModeratorUserId], references: [id], onDelete: SetNull)
  reviewedBy             User?            @relation("UserReportsReviewed", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  conversation           Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message                Message?         @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([reporterUserId, status])
  @@index([targetUserId, status])
  @@index([assignedModeratorUserId, status])
  @@index([reviewedByUserId, status])
  @@index([conversationId])
  @@index([messageId])
  @@map("user_reports")
}

model Call {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String            @db.Uuid
  startedById    String?           @db.Uuid
  type           CallType
  status         CallStatus        @default(RINGING)
  startedAt      DateTime          @default(now())
  endedAt        DateTime?
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  startedBy      User?             @relation("StartedCalls", fields: [startedById], references: [id], onDelete: SetNull)
  participants   CallParticipant[]

  @@index([conversationId, startedAt])
  @@index([startedById])
  @@map("calls")
}

model CallParticipant {
  id       String    @id @default(uuid()) @db.Uuid
  callId   String    @db.Uuid
  userId   String    @db.Uuid
  joinedAt DateTime?
  leftAt   DateTime?
  call     Call      @relation(fields: [callId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId, userId])
  @@index([userId])
  @@map("call_participants")
}

model UserStatusPost {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @db.Uuid
  removedByUserId String?            @db.Uuid
  type            UserStatusPostType
  text            String?
  caption         String?
  backgroundColor String?
  textColor       String?
  mediaProvider   MediaProvider?
  mediaBucket     String?
  mediaStorageKey String?
  mediaUrl        String?
  mediaMimeType   String?
  mediaSizeBytes  Int?
  mediaWidth      Int?
  mediaHeight     Int?
  mediaDurationMs Int?
  mediaChecksum   String?
  expiresAt       DateTime
  removedAt       DateTime?
  removedReason   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation("AuthoredStatuses", fields: [userId], references: [id], onDelete: Cascade)
  removedBy       User?              @relation("ModeratedStatuses", fields: [removedByUserId], references: [id], onDelete: SetNull)
  views           UserStatusView[]
  reactions       UserStatusReaction[]
  comments        UserStatusComment[]

  @@index([userId, createdAt])
  @@index([userId, expiresAt])
  @@index([expiresAt, removedAt])
  @@index([removedByUserId])
  @@map("user_status_posts")
}

model UserStatusView {
  id           String         @id @default(uuid()) @db.Uuid
  statusPostId String         @db.Uuid
  viewerUserId String         @db.Uuid
  viewedAt     DateTime       @default(now())
  statusPost   UserStatusPost @relation(fields: [statusPostId], references: [id], onDelete: Cascade)
  viewer       User           @relation("ViewedStatusPosts", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([statusPostId, viewerUserId])
  @@index([viewerUserId, viewedAt])
  @@map("user_status_views")
}

model UserStatusReaction {
  id           String         @id @default(uuid()) @db.Uuid
  statusPostId String         @db.Uuid
  userId       String         @db.Uuid
  emoji        String
  createdAt    DateTime       @default(now())
  statusPost   UserStatusPost @relation(fields: [statusPostId], references: [id], onDelete: Cascade)
  user         User           @relation("ReactedStatusPosts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([statusPostId, userId])
  @@index([userId, createdAt])
  @@map("user_status_reactions")
}

model UserStatusComment {
  id             String         @id @default(uuid()) @db.Uuid
  statusPostId   String         @db.Uuid
  userId         String         @db.Uuid
  conversationId String?        @db.Uuid
  messageId      String?        @db.Uuid
  body           String
  createdAt      DateTime       @default(now())
  statusPost     UserStatusPost @relation(fields: [statusPostId], references: [id], onDelete: Cascade)
  user           User           @relation("CommentedStatusPosts", fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  message        Message?       @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([statusPostId, createdAt])
  @@index([userId, createdAt])
  @@index([conversationId])
  @@index([messageId])
  @@map("user_status_comments")
}

model DirectMessageRequest {
  id              String                     @id @default(uuid()) @db.Uuid
  requesterUserId String                     @db.Uuid
  recipientUserId String                     @db.Uuid
  conversationId  String?                    @db.Uuid
  initialMessage  String?
  status          DirectMessageRequestStatus @default(PENDING)
  respondedAt     DateTime?
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  requester       User                       @relation("OutgoingDirectMessageRequests", fields: [requesterUserId], references: [id], onDelete: Cascade)
  recipient       User                       @relation("IncomingDirectMessageRequests", fields: [recipientUserId], references: [id], onDelete: Cascade)
  conversation    Conversation?              @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@index([requesterUserId, status])
  @@index([recipientUserId, status])
  @@index([conversationId])
  @@map("direct_message_requests")
}
