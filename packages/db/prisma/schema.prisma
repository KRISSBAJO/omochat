  id                  String                                     @id @default(uuid()) @db.Uuid
  conversationId      String                                     @db.Uuid
  leaveBalanceId      String                                     @db.Uuid @map("leave_balance_id")
  leavePolicyId       String                                     @db.Uuid @map("leave_policy_id")
  userId              String                                     @db.Uuid
  actorUserId         String?                                    @db.Uuid @map("actor_user_id")
  leaveRequestId      String?                                    @db.Uuid @map("leave_request_id")
  entryType           ConversationAttendanceLeaveBalanceEntryType @map("entry_type")
  minutesDelta        Int                                        @map("minutes_delta")
  balanceAfterMinutes Int                                        @map("balance_after_minutes")
  note                String?
  effectiveAt         DateTime                                   @default(now()) @map("effective_at")
  createdAt           DateTime                                   @default(now())
  conversation        Conversation                               @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  leaveBalance        ConversationAttendanceLeaveBalance         @relation(fields: [leaveBalanceId], references: [id], onDelete: Cascade)
  leavePolicy         ConversationAttendanceLeavePolicy          @relation(fields: [leavePolicyId], references: [id], onDelete: Cascade)
  user                User                                       @relation("ConversationAttendanceLeaveBalanceEntryUsers", fields: [userId], references: [id], onDelete: Cascade)
  actor               User?                                      @relation("ConversationAttendanceLeaveBalanceEntryActors", fields: [actorUserId], references: [id], onDelete: SetNull)
  leaveRequest        ConversationAttendanceLeaveRequest?        @relation(fields: [leaveRequestId], references: [id], onDelete: SetNull)

  @@index([conversationId, effectiveAt])
  @@index([leaveBalanceId, effectiveAt])
  @@index([leaveRequestId])
  @@map("conversation_attendance_leave_balance_entries")
}

model ConversationAttendanceRotaRun {
  id                  String                            @id @default(uuid()) @db.Uuid
  conversationId      String                            @db.Uuid
  templateId          String                            @db.Uuid @map("template_id")
  createdById         String                            @db.Uuid @map("created_by_id")
  title               String
  frequency           ConversationAttendanceRotaFrequency
  startsOn            DateTime                          @map("starts_on")
  endsOn              DateTime                          @map("ends_on")
  participantUserIds  String[]                          @default([]) @map("participant_user_ids")
  generatedShiftCount Int                               @default(0) @map("generated_shift_count")
  isActive            Boolean                           @default(true) @map("is_active")
  lastGeneratedAt     DateTime?                         @map("last_generated_at")
  createdAt           DateTime                          @default(now())
  updatedAt           DateTime                          @updatedAt
  conversation        Conversation                      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  template            ConversationAttendanceShiftTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdBy           User                              @relation("ConversationAttendanceRotaRunCreators", fields: [createdById], references: [id], onDelete: Cascade)
  shifts              ConversationAttendanceShift[]

  @@index([conversationId, createdAt])
  @@index([templateId, startsOn])
  @@map("conversation_attendance_rota_runs")
}

model ConversationAttendanceAuditLog {
