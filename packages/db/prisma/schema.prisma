generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DirectMessagePolicy {
  OPEN
  REQUESTS_ONLY
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
}

enum ConversationCategory {
  GENERAL
  CHURCH
  WORKSPACE
  COMMUNITY
  DEPARTMENT
  CARE_TEAM
}

enum ParticipantRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  SYSTEM
  CALL
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

enum MediaProvider {
  LOCAL
  S3
  CLOUDINARY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum NotificationType {
  SYSTEM
  MESSAGE_REQUEST
  MESSAGE_REQUEST_ACCEPTED
  MESSAGE_REQUEST_DECLINED
  MESSAGE_RECEIVED
  CALL_RINGING
  CALL_MISSED
  REPORT_UPDATED
  USER_BLOCKED
  USER_REPORTED
}

enum CallType {
  VOICE
  VIDEO
}

enum CallStatus {
  RINGING
  ANSWERED
  MISSED
  ENDED
  FAILED
}

enum DirectMessageRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum UserReportStatus {
  OPEN
  REVIEWED
  DISMISSED
}

enum PlatformRole {
  SITE_ADMIN
  PLATFORM_ADMIN
  MODERATOR
}

enum AdminActionType {
  USER_SUSPENDED
  USER_RESTORED
  USER_ROLE_UPDATED
}

enum ConversationToolPack {
  CORE_WORKSPACE
  COMMUNITY_CARE
  BOARDS
  ATTENDANCE
}

enum ConversationBoardTemplate {
  KANBAN
  SPRINT
  CUSTOM
}

enum ConversationBoardSprintStatus {
  PLANNED
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ConversationBoardMemberRole {
  MANAGER
  EDITOR
  CONTRIBUTOR
  VIEWER
}

enum ConversationAttendanceShiftStatus {
  DRAFT
  PUBLISHED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ConversationAttendanceAssignmentStatus {
  ASSIGNED
  CONFIRMED
  DECLINED
  CALLED_OFF
}

enum ConversationAttendanceClockEventType {
  CLOCK_IN
  BREAK_START
  BREAK_END
  CLOCK_OUT
  ADJUSTMENT
}

enum ConversationAttendanceClockMethod {
  WEB
  MOBILE
  QR
  NFC
  PHOTO
  MANUAL
  KIOSK
}

enum ConversationAttendanceRecordStatus {
  ON_CLOCK
  ON_BREAK
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ABSENT
}

enum ConversationAttendanceExceptionFlag {
  LATE
  EARLY_LEAVE
  OVERTIME
  MISSED_CLOCK_OUT
  LOCATION_EXCEPTION
  MANUAL_REVIEW
}

enum ConversationAttendanceLeaveType {
  VACATION
  SICK
  PERSONAL
  COMPASSIONATE
  MINISTRY
  HOLIDAY
  UNPAID
  OTHER
}

enum ConversationAttendanceLeaveStatus {
  DRAFT
  PENDING
  APPROVED
  DECLINED
  CANCELLED
}

enum ConversationAttendanceHolidayScope {
  ROOM
  CATEGORY
  GLOBAL
}

enum ConversationAttendanceLeaveAccrualCadence {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  MANUAL
}

enum ConversationAttendanceLeaveBalanceEntryType {
  OPENING
  ACCRUAL
  ADJUSTMENT
  REQUEST_APPROVAL
  REQUEST_REVERSAL
  CARRY_OVER
}

enum ConversationAttendanceRotaFrequency {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum ConversationAttendanceExportVariant {
  SUMMARY
  TIMESHEET
  PAYROLL
  LEAVE
  AUDIT
}

enum ConversationAttendanceAuditAction {
  POLICY_UPDATED
  HOLIDAY_CREATED
  HOLIDAY_UPDATED
  LEAVE_POLICY_CREATED
  LEAVE_POLICY_UPDATED
  LEAVE_BALANCE_ADJUSTED
  LEAVE_ACCRUAL_APPLIED
  LEAVE_REQUEST_CREATED
  LEAVE_REQUEST_REVIEWED
  SHIFT_TEMPLATE_CREATED
  SHIFT_TEMPLATE_UPDATED
  SHIFT_CREATED
  SHIFT_UPDATED
  ROTA_GENERATED
  CLOCK_EVENT_RECORDED
  RECORD_REVIEWED
  EXPORT_GENERATED
}

enum ConversationToolRequestStatus {
  PENDING
  APPROVED
  DECLINED
}

enum ConversationNoteKind {
  NOTE
  ANNOUNCEMENT
}

enum ConversationTaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum ConversationTaskType {
  TASK
  FEATURE
  BUG
  IMPROVEMENT
  FOLLOW_UP
  REQUEST
}

enum ConversationTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PrayerRequestStatus {
  OPEN
  ANSWERED
  ARCHIVED
}

enum CareRequestType {
  PRAYER
  FOLLOW_UP
  VISITATION
  COUNSELING
  SUPPORT
  WELFARE
  GUEST
}

enum CareRequestVisibility {
  PRIVATE
  CARE_TEAM
  ROOM
}

enum ConversationAnnouncementAudience {
  ROOM
  LEADS_ONLY
  CARE_TEAM
  FOLLOW_UP_TEAM
  NEW_GUESTS
}

enum UserStatusPostType {
  TEXT
  IMAGE
  VIDEO
}

model Tenant {
  id            String         @id @default(uuid()) @db.Uuid
  name          String
  slug          String         @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  conversations Conversation[]

  @@map("tenants")
}

model User {
  id                      String                    @id @default(uuid()) @db.Uuid
  tenantId                String?                   @db.Uuid
  email                   String                    @unique
  username                String                    @unique
  userCode                String?                   @unique
  displayName             String
  avatarUrl               String?
  statusMessage           String?
  bio                     String?
  addressLine1            String?
  city                    String?
  stateRegion             String?
  countryCode             String?
  latitude                Float?
  longitude               Float?
  phoneNumber             String?                   @unique
  phoneVerifiedAt         DateTime?
  passwordHash            String
  dmPolicy                DirectMessagePolicy       @default(OPEN)
  status                  UserStatus                @default(ACTIVE)
  lastSeenAt              DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  tenant                  Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  devices                 Device[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  participants            ConversationParticipant[]
  sentMessages            Message[]                 @relation("SentMessages")
  receipts                MessageReceipt[]
  reactions               MessageReaction[]
  notifications           Notification[]
  pushSubscriptions       PushSubscription[]
  createdConversations    Conversation[]            @relation("CreatedConversations")
  startedCalls            Call[]                    @relation("StartedCalls")
  callParticipants        CallParticipant[]
  outgoingMessageRequests DirectMessageRequest[]    @relation("OutgoingDirectMessageRequests")
  incomingMessageRequests DirectMessageRequest[]    @relation("IncomingDirectMessageRequests")
  blocksInitiated         UserBlock[]               @relation("UserBlocksInitiated")
  blocksReceived          UserBlock[]               @relation("UserBlocksReceived")
  reportsFiled            UserReport[]              @relation("UserReportsFiled")
  reportsReceived         UserReport[]              @relation("UserReportsReceived")
  reportsAssigned         UserReport[]              @relation("UserReportsAssigned")
  reportsReviewed         UserReport[]              @relation("UserReportsReviewed")
  platformRoles           UserPlatformRole[]        @relation("UserPlatformRoles")
  assignedPlatformRoles   UserPlatformRole[]        @relation("AssignedPlatformRoles")
  adminActionsTaken       UserAdminAction[]         @relation("AdminActionsTaken")
  adminActionsReceived    UserAdminAction[]         @relation("AdminActionsReceived")
  authoredStatuses        UserStatusPost[]          @relation("AuthoredStatuses")
  moderatedStatuses       UserStatusPost[]          @relation("ModeratedStatuses")
  viewedStatusPosts       UserStatusView[]          @relation("ViewedStatusPosts")
  statusReactions         UserStatusReaction[]      @relation("ReactedStatusPosts")
  statusComments          UserStatusComment[]       @relation("CommentedStatusPosts")
  requestedToolPacks      ConversationToolRequest[] @relation("RequestedConversationToolPacks")
  reviewedToolPacks       ConversationToolRequest[] @relation("ReviewedConversationToolPacks")
  activatedToolPacks      ConversationToolActivation[]
  createdBoards           ConversationBoard[]       @relation("ConversationBoardCreators")
  boardMemberships        ConversationBoardMember[] @relation("ConversationBoardMembers")
  invitedBoardMembers     ConversationBoardMember[] @relation("ConversationBoardMemberInviters")
  createdBoardSprints     ConversationBoardSprint[] @relation("ConversationBoardSprintCreators")
  authoredToolNotes       ConversationToolNote[]    @relation("ConversationToolNoteAuthors")
  updatedToolNotes        ConversationToolNote[]    @relation("ConversationToolNoteEditors")
  createdToolTasks        ConversationToolTask[]    @relation("ConversationToolTaskCreators")
  assignedToolTasks       ConversationToolTask[]    @relation("ConversationToolTaskAssignees")
  watchedToolTasks        ConversationToolTaskWatcher[] @relation("ConversationToolTaskWatchers")
  likedToolTasks          ConversationToolTaskLike[] @relation("ConversationToolTaskLikes")
  authoredToolTaskComments ConversationToolTaskComment[] @relation("ConversationToolTaskCommentAuthors")
  uploadedToolTaskAttachments ConversationToolTaskAttachment[] @relation("ConversationToolTaskAttachmentUploaders")
  createdToolPolls        ConversationToolPoll[]    @relation("ConversationToolPollCreators")
  toolPollVotes           ConversationToolPollVote[]
  createdPrayerRequests   ConversationPrayerRequest[] @relation("ConversationPrayerRequestCreators")
  assignedPrayerRequests  ConversationPrayerRequest[] @relation("ConversationPrayerRequestAssignees")
  prayerRequestSupports   ConversationPrayerSupport[]
  prayerRequestUpdates    ConversationPrayerUpdate[] @relation("ConversationPrayerUpdateAuthors")
  createdAttendanceTemplates ConversationAttendanceShiftTemplate[] @relation("ConversationAttendanceTemplateCreators")
  createdAttendanceShifts ConversationAttendanceShift[] @relation("ConversationAttendanceShiftCreators")
  attendanceAssignments ConversationAttendanceAssignment[] @relation("ConversationAttendanceAssignments")
  assignedAttendanceEntries ConversationAttendanceAssignment[] @relation("ConversationAttendanceAssignmentCreators")
  attendanceRecords ConversationAttendanceRecord[] @relation("ConversationAttendanceRecords")
  reviewedAttendanceRecords ConversationAttendanceRecord[] @relation("ConversationAttendanceRecordReviewers")
  attendanceClockEvents ConversationAttendanceClockEvent[] @relation("ConversationAttendanceClockEventActors")
  createdAttendancePolicies ConversationAttendancePolicy[] @relation("ConversationAttendancePolicyCreators")
  updatedAttendancePolicies ConversationAttendancePolicy[] @relation("ConversationAttendancePolicyEditors")
  createdAttendanceHolidays ConversationAttendanceHoliday[] @relation("ConversationAttendanceHolidayCreators")
  createdAttendanceLeavePolicies ConversationAttendanceLeavePolicy[] @relation("ConversationAttendanceLeavePolicyCreators")
  updatedAttendanceLeavePolicies ConversationAttendanceLeavePolicy[] @relation("ConversationAttendanceLeavePolicyEditors")
  attendanceLeaveBalances ConversationAttendanceLeaveBalance[] @relation("ConversationAttendanceLeaveBalances")
  attendanceLeaveBalanceEntrySubjects ConversationAttendanceLeaveBalanceEntry[] @relation("ConversationAttendanceLeaveBalanceEntryUsers")
  attendanceLeaveBalanceEntries ConversationAttendanceLeaveBalanceEntry[] @relation("ConversationAttendanceLeaveBalanceEntryActors")
  createdAttendanceRotaRuns ConversationAttendanceRotaRun[] @relation("ConversationAttendanceRotaRunCreators")
  attendanceAuditLogs ConversationAttendanceAuditLog[] @relation("ConversationAttendanceAuditLogActors")
  requestedAttendanceLeaves ConversationAttendanceLeaveRequest[] @relation("ConversationAttendanceLeaveRequestUsers")
  reviewedAttendanceLeaves ConversationAttendanceLeaveRequest[] @relation("ConversationAttendanceLeaveRequestReviewers")

  @@index([tenantId])
  @@index([status])
  @@index([dmPolicy])
  @@map("users")
}

model UserPlatformRole {
  id               String       @id @default(uuid()) @db.Uuid
  userId           String       @db.Uuid
  role             PlatformRole
  assignedByUserId String?      @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation("UserPlatformRoles", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy       User?        @relation("AssignedPlatformRoles", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@unique([userId, role])
  @@index([role])
  @@index([assignedByUserId])
  @@map("user_platform_roles")
}

model UserAdminAction {
  id           String          @id @default(uuid()) @db.Uuid
  targetUserId String          @db.Uuid
  actorUserId  String?         @db.Uuid
  type         AdminActionType
  note         String?
  createdAt    DateTime        @default(now())
  targetUser   User            @relation("AdminActionsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  actorUser    User?           @relation("AdminActionsTaken", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([type, createdAt])
  @@map("user_admin_actions")
}

model PushSubscription {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  endpoint   String   @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastUsedAt DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("push_subscriptions")
}

model Device {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @db.Uuid
  label         String?
  platform      String
  pushToken     String?
  publicKey     String?
  lastSeenAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([pushToken])
  @@map("devices")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  deviceId  String?   @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  device    Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Conversation {
  id                      String                    @id @default(uuid()) @db.Uuid
  tenantId                String?                   @db.Uuid
  createdById             String?                   @db.Uuid
  type                    ConversationType
  category                ConversationCategory      @default(GENERAL)
  title                   String?
  description             String?
  avatarUrl               String?
  inviteCode              String?                   @unique @map("invite_code")
  inviteCodeCreatedAt     DateTime?                 @map("invite_code_created_at")
  inviteCodeExpiresAt     DateTime?                 @map("invite_code_expires_at")
  lastMessageAt           DateTime?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  tenant                  Tenant?                   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdBy               User?                     @relation("CreatedConversations", fields: [createdById], references: [id], onDelete: SetNull)
  participants            ConversationParticipant[]
  messages                Message[]
  calls                   Call[]
  acceptedMessageRequests DirectMessageRequest[]
  reports                 UserReport[]
  statusComments          UserStatusComment[]
  toolRequests            ConversationToolRequest[]
  toolActivations         ConversationToolActivation[]
  boards                  ConversationBoard[]
  toolNotes               ConversationToolNote[]
  toolTasks               ConversationToolTask[]
  toolPolls               ConversationToolPoll[]
  prayerRequests          ConversationPrayerRequest[]
  attendanceTemplates     ConversationAttendanceShiftTemplate[]
  attendanceShifts        ConversationAttendanceShift[]
  attendanceRecords       ConversationAttendanceRecord[]
  attendancePolicy        ConversationAttendancePolicy?
  attendanceHolidays      ConversationAttendanceHoliday[]
  attendanceLeavePolicies ConversationAttendanceLeavePolicy[]
  attendanceLeaveBalances ConversationAttendanceLeaveBalance[]
  attendanceLeaveBalanceEntries ConversationAttendanceLeaveBalanceEntry[]
  attendanceRotaRuns      ConversationAttendanceRotaRun[]
  attendanceAuditLogs     ConversationAttendanceAuditLog[]
  attendanceLeaveRequests ConversationAttendanceLeaveRequest[]

  @@index([tenantId])
  @@index([type])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationParticipant {
  id                String          @id @default(uuid()) @db.Uuid
  conversationId    String          @db.Uuid
  userId            String          @db.Uuid
  role              ParticipantRole @default(MEMBER)
  pinnedAt          DateTime?
  lockedAt          DateTime?
  mutedUntil        DateTime?
  archivedAt        DateTime?
  lastReadAt        DateTime?
  lastReadMessageId String?         @db.Uuid
  joinedAt          DateTime        @default(now())
  leftAt            DateTime?
  conversation      Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([userId, archivedAt])
  @@index([userId, lockedAt])
  @@index([userId, pinnedAt])
  @@map("conversation_participants")
}

model Message {
  id             String            @id @default(uuid()) @db.Uuid
  conversationId String            @db.Uuid
  senderId       String?           @db.Uuid
  parentId       String?           @db.Uuid
  type           MessageType       @default(TEXT)
  body           String?
  encryptedBody  String?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?             @relation("SentMessages", fields: [senderId], references: [id], onDelete: SetNull)
  parent         Message?          @relation("ThreadedMessages", fields: [parentId], references: [id], onDelete: SetNull)
  replies        Message[]         @relation("ThreadedMessages")
  media          MediaAsset[]
  receipts       MessageReceipt[]
  reactions      MessageReaction[]
  notifications  Notification[]
  reports        UserReport[]
  statusComments UserStatusComment[]
  toolTasks      ConversationToolTask[]

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([parentId])
  @@map("messages")
}

model MessageReceipt {
  id          String        @id @default(uuid()) @db.Uuid
  messageId   String        @db.Uuid
  userId      String        @db.Uuid
  status      MessageStatus
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  message     Message       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, status])
  @@map("message_receipts")
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  userId    String   @db.Uuid
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([userId])
  @@map("message_reactions")
}

model ConversationToolRequest {
  id               String                        @id @default(uuid()) @db.Uuid
  conversationId   String                        @db.Uuid
  requestedByUserId String                       @db.Uuid @map("requested_by_user_id")
  reviewedByUserId String?                       @db.Uuid @map("reviewed_by_user_id")
  pack             ConversationToolPack
  status           ConversationToolRequestStatus @default(PENDING)
  note             String?
  reviewNote       String?                       @map("review_note")
  reviewedAt       DateTime?                     @map("reviewed_at")
  createdAt        DateTime                      @default(now())
  updatedAt        DateTime                      @updatedAt
  conversation     Conversation                  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  requestedBy      User                          @relation("RequestedConversationToolPacks", fields: [requestedByUserId], references: [id], onDelete: Cascade)
  reviewedBy       User?                         @relation("ReviewedConversationToolPacks", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@map("conversation_tool_requests")
}

model ConversationToolActivation {
  id                String               @id @default(uuid()) @db.Uuid
  conversationId    String               @db.Uuid
  activatedByUserId String?              @db.Uuid @map("activated_by_user_id")
  pack              ConversationToolPack
  activatedAt       DateTime             @default(now()) @map("activated_at")
  updatedAt         DateTime             @updatedAt
  conversation      Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  activatedBy       User?                @relation(fields: [activatedByUserId], references: [id], onDelete: SetNull)

  @@unique([conversationId, pack])
  @@index([pack, activatedAt])
  @@map("conversation_tool_activations")
}

model ConversationBoard {
  id             String                    @id @default(uuid()) @db.Uuid
  conversationId String                    @db.Uuid
  createdById    String                    @db.Uuid
  title          String
  description    String?
  codePrefix     String                    @default("ROOM") @map("code_prefix")
  nextTaskNumber Int                       @default(1) @map("next_task_number")
  template       ConversationBoardTemplate @default(KANBAN)
  isDefault      Boolean                   @default(false) @map("is_default")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  conversation   Conversation              @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdBy      User                      @relation("ConversationBoardCreators", fields: [createdById], references: [id], onDelete: Cascade)
  columns        ConversationBoardColumn[]
  members        ConversationBoardMember[]
  sprints        ConversationBoardSprint[]
  tasks          ConversationToolTask[]

  @@index([conversationId, createdAt])
  @@index([conversationId, isDefault])
  @@map("conversation_boards")
}

model ConversationBoardSprint {
  id         String                       @id @default(uuid()) @db.Uuid
  boardId     String                      @db.Uuid
  createdById String                      @db.Uuid @map("created_by_id")
  title      String
  goal       String?
  status     ConversationBoardSprintStatus @default(PLANNED)
  startsAt   DateTime?                    @map("starts_at")
  endsAt     DateTime?                    @map("ends_at")
  sortOrder  Int                          @default(0) @map("sort_order")
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
  board      ConversationBoard            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy  User                         @relation("ConversationBoardSprintCreators", fields: [createdById], references: [id], onDelete: Cascade)
  tasks      ConversationToolTask[]

  @@index([boardId, sortOrder])
  @@index([boardId, status])
  @@map("conversation_board_sprints")
}

model ConversationBoardColumn {
  id         String                 @id @default(uuid()) @db.Uuid
  boardId    String                 @db.Uuid
  title      String
  color      String?
  sortOrder  Int                    @default(0) @map("sort_order")
  taskStatus ConversationTaskStatus @default(TODO) @map("task_status")
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  board      ConversationBoard      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks      ConversationToolTask[]

  @@index([boardId, sortOrder])
  @@map("conversation_board_columns")
}

model ConversationBoardMember {
  id            String                      @id @default(uuid()) @db.Uuid
  boardId       String                      @db.Uuid
  userId        String                      @db.Uuid
  addedByUserId String?                     @db.Uuid @map("added_by_user_id")
  role          ConversationBoardMemberRole @default(CONTRIBUTOR)
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt
  board         ConversationBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user          User                        @relation("ConversationBoardMembers", fields: [userId], references: [id], onDelete: Cascade)
  addedBy       User?                       @relation("ConversationBoardMemberInviters", fields: [addedByUserId], references: [id], onDelete: SetNull)

  @@unique([boardId, userId])
  @@index([boardId, role])
  @@index([userId, createdAt])
  @@map("conversation_board_members")
}

model ConversationToolNote {
  id             String               @id @default(uuid()) @db.Uuid
  conversationId String               @db.Uuid
  createdById    String               @db.Uuid
  updatedById    String?              @db.Uuid
