  actor          User?                            @relation("ConversationAttendanceAuditLogActors", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([action, createdAt])
  @@map("conversation_attendance_audit_logs")
