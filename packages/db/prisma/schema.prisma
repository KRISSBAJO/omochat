model ConversationAttendanceLeaveRequest {
  id               String                            @id @default(uuid()) @db.Uuid
  conversationId   String                            @db.Uuid
  policyId         String?                           @db.Uuid @map("policy_id")
  leavePolicyId    String?                           @db.Uuid @map("leave_policy_id")
  userId           String                            @db.Uuid
  reviewedByUserId String?                           @db.Uuid @map("reviewed_by_user_id")
  leaveType        ConversationAttendanceLeaveType   @default(PERSONAL) @map("leave_type")
  status           ConversationAttendanceLeaveStatus @default(PENDING)
  title            String
  reason           String?
  startsAt         DateTime                          @map("starts_at")
  endsAt           DateTime                          @map("ends_at")
  minutesRequested Int                               @default(0) @map("minutes_requested")
  isPartialDay     Boolean                           @default(false) @map("is_partial_day")
  deductFromBalance Boolean                          @default(true) @map("deduct_from_balance")
  reviewNote       String?                           @map("review_note")
  decidedAt        DateTime?                         @map("decided_at")
  createdAt        DateTime                          @default(now())
  updatedAt        DateTime                          @updatedAt
  conversation     Conversation                      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  policy           ConversationAttendancePolicy?     @relation(fields: [policyId], references: [id], onDelete: SetNull)
  leavePolicy      ConversationAttendanceLeavePolicy? @relation(fields: [leavePolicyId], references: [id], onDelete: SetNull)
  user             User                              @relation("ConversationAttendanceLeaveRequestUsers", fields: [userId], references: [id], onDelete: Cascade)
